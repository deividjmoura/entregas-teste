# Banco (Neon)
DATABASE_URL="postgresql://usuario:senha@host/banco?sslmode=require"

# Firebase (Authentication -> Google) — pegue em:
# Console Firebase -> Configurações do projeto -> Geral -> "Seus apps" -> app Web
