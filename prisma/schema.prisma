generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Solicitacao {
  id                  String    @id @default(uuid())
  tipo                String
  descricaoItem       String
  localDestino        String
  rackOuSlide         String?
  enderecoEstoque     String?
  enderecoAlteradoPor String?
  foto                String?   @db.Text
  temFoto             Boolean   @default(false)
  urgencia            String
  status              String    @default("PENDENTE")
  solicitanteNome     String
  entregadorNome      String?
  versao              Int       @default(1)
  criadaEm            DateTime  @default(now())
  atualizadaEm        DateTime  @updatedAt
  entregueEm          DateTime?

  mensagens           Mensagem[]

  @@index([status, urgencia])
}

model ItemEstoque {
  id            String   @id @default(uuid())
  nomeItem      String   @unique
  endereco      String?
  foto          String?  @db.Text
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  historicoEndereco HistoricoEnderecoEstoque[]

  @@index([nomeItem])
}

// Guarda só quem mudou o endereço e quando — não versiona a foto,
// só o endereço, que é o campo que o entregador pode alterar.
model HistoricoEnderecoEstoque {
  id             String      @id @default(uuid())
  itemId         String
  item           ItemEstoque @relation(fields: [itemId], references: [id], onDelete: Cascade)
  enderecoAntigo String?
  enderecoNovo   String?
  alteradoPor    String
  alteradoEm     DateTime    @default(now())

  @@index([itemId, alteradoEm])
}
model Mensagem {
  id            String      @id @default(uuid())
  solicitacaoId String
  solicitacao   Solicitacao @relation(fields: [solicitacaoId], references: [id], onDelete: Cascade)
  autorNome     String
  autorTipo     String
  texto         String
  criadaEm      DateTime    @default(now())

  @@index([solicitacaoId, criadaEm])
}

model Presenca {
  sessionId    String   @id
  atualizadaEm DateTime @updatedAt
}