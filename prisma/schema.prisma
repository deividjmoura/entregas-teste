generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Solicitacao {
  id              String    @id @default(uuid())
  tipo            String
  descricaoItem   String
  localDestino    String
  rackOuSlide     String?
  foto            String?   @db.Text
  urgencia        String
  status          String    @default("PENDENTE")
  solicitanteNome String
  entregadorNome  String?
  versao          Int       @default(1)
  criadaEm        DateTime  @default(now())
  atualizadaEm    DateTime  @updatedAt
  entregueEm      DateTime? // marcado só quando status vira ENTREGUE — usado pra medir tempo de despacho

  @@index([status, urgencia])
}

// Contador simples de "usuários online" pro banner de demo — cada aba manda
// heartbeat a cada 5s, e consideramos online quem bateu nos últimos 15s.
model Presenca {
  sessionId    String   @id
  atualizadaEm DateTime @updatedAt
}